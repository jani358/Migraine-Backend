{
  "kind": "collectionType",
  "collectionName": "text_testimonials",
  "info": {
    "singularName": "text-testimonial",
    "pluralName": "text-testimonials",
    "displayName": "Text Testimonial",
    "description": "Written patient reviews — the 'What Our Clients Say' section."
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "location": {
      "type": "string"
    },
    "quote": {
      "type": "text",
      "required": true
    },
    "rating": {
      "type": "integer",
      "min": 1,
      "max": 5,
      "default": 5
    },
    "avatar": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "order": {
      "type": "integer",
      "default": 0
    }
  }
}
